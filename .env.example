# =============================================================================
# DCI Multi-Agent -- Machine-Specific Secrets
#
# This file contains ONLY per-machine secrets (credentials, key paths).
# All run settings (target server, model, retry count, etc.) are in
# run_config.yml -- the single source of truth.
#
# This file is NOT committed to git. Copy it to .env and fill in values.
# =============================================================================

# === Mac settings ===

# Claude via Vertex AI
ANTHROPIC_VERTEX_PROJECT_ID="your-vertex-project-id"

# Pub/Sub (separate GCP project from Vertex AI)
GCP_PUBSUB_PROJECT_ID="your-pubsub-project-id"
# SA key loaded explicitly by pubsub_client.py (not via GOOGLE_APPLICATION_CREDENTIALS,
# which would override Vertex AI's application-default credentials)
PUBSUB_SA_KEY_PATH="/path/to/infra/dci-relay-sa-key.json"

# Local repo clone path
DCI_LOCAL_REPO_ROOT="."

# Logging directory
DCI_LOG_DIR="/tmp/dci-agent-logs"


# === Relay machine settings ===
# (Only needed on the relay machine, not on Mac)

# GOOGLE_APPLICATION_CREDENTIALS="/path/to/dci-relay-sa-key.json"
# JUMPBOX_SSH_KEY="/path/to/.ssh/id_ed25519"
# GCP_PUBSUB_PROJECT_ID="your-pubsub-project-id"

# Target server password (used by relay to SSH into target servers)
# DCI_TARGET_PASSWORD="your-target-password"

# Comma-separated fallback passwords for target servers
# DCI_FALLBACK_PASSWORDS="password1,password2"
